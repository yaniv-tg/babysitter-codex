{
  "upstreamRepo": "a5c-ai/babysitter",
  "upstreamBranch": "staging",
  "mappings": [
    {
      "upstream": "plugins/babysitter/skills",
      "local": ".codex/skills"
    },
    {
      "upstream": "plugins/babysitter/agents",
      "local": "agents"
    },
    {
      "upstream": "plugins/babysitter/AGENTS.md",
      "local": ".codex/AGENTS.md"
    }
  ],
  "ignore": [
    "**/.a5c/**",
    "**/node_modules/**",
    "**/.git/**"
  ]
}
