<!--
  Node Template Reference (AWS)

  This file contains template patterns for adding shapes to DrawIO diagrams.
  Copy and customize these patterns, replacing placeholder values.

  Placeholders:
  - {ID}             : Unique identifier using full service name (e.g., "lambda_processor", "s3_static_assets")
  - {LABEL}          : Display text (e.g., "AWS Lambda", "Amazon S3")
  - {PARENT}         : Parent cell ID ("1" for root, or container ID)
  - {X}, {Y}         : Position in pixels
  - {WIDTH}, {HEIGHT} : Dimensions in pixels (containers only)
  - {CATEGORY_COLOR} : Category fill color (e.g., "#ED7100" for Compute)
  - {SHAPE_NAME}     : AWS shape name using UNDERSCORES for multi-word (e.g., "lambda", "s3", "step_functions")

  CRITICAL: Always use resourceIcon/resIcon, NEVER productIcon/prIcon.
  CRITICAL: Multi-word names use UNDERSCORES: "step_functions", NOT "step functions".
-->

<!-- ============================================
     AWS SERVICE ICON (with colored square background)
     Use when labeling the AWS service itself.
     Example labels: "AWS Lambda", "Amazon S3", "Amazon RDS"
     strokeColor=#ffffff matches DrawIO stencil default — enables internal white line artwork.
     ============================================ -->
<mxCell id="{ID}"
  value="{LABEL}"
  style="sketch=0;points=[[0,0,0],[0.25,0,0],[0.5,0,0],[0.75,0,0],[1,0,0],[0,1,0],[0.25,1,0],[0.5,1,0],[0.75,1,0],[1,1,0],[0,0.25,0],[0,0.5,0],[0,0.75,0],[1,0.25,0],[1,0.5,0],[1,0.75,0]];outlineConnect=0;fontColor=#232F3E;fillColor={CATEGORY_COLOR};strokeColor=#ffffff;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.resourceIcon;resIcon=mxgraph.aws4.{SHAPE_NAME}"
  vertex="1"
  parent="{PARENT}">
  <mxGeometry x="{X}" y="{Y}" width="64" height="64" as="geometry" />
</mxCell>


<!-- ============================================
     AWS INSTANCE ICON (bare icon, no background)
     Use when representing a specific resource/instance.
     Example labels: "Order Processor", "User Auth", "ECS Task 1"
     strokeColor=none (no background square to outline).
     ============================================ -->
<mxCell id="{ID}"
  value="{LABEL}"
  style="sketch=0;outlineConnect=0;fontColor=#232F3E;fillColor={CATEGORY_COLOR};strokeColor=none;dashed=0;verticalLabelPosition=bottom;verticalAlign=top;align=center;html=1;fontSize=12;fontStyle=0;aspect=fixed;shape=mxgraph.aws4.{SHAPE_NAME}"
  vertex="1"
  parent="{PARENT}">
  <mxGeometry x="{X}" y="{Y}" width="64" height="64" as="geometry" />
</mxCell>


