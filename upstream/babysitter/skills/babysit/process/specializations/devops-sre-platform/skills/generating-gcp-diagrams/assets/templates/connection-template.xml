<!-- ============================================
     CONNECTION WITH WAYPOINTS
     For complex routing around obstacles
     ============================================ -->
<mxCell id="{ID}"
  value="{LABEL}"
  style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=1;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#333333;"
  edge="1"
  parent="{PARENT}"
  source="{SOURCE}"
  target="{TARGET}">
  <mxGeometry relative="1" as="geometry">
    <Array as="points">
      <mxPoint x="200" y="150" />
      <mxPoint x="200" y="250" />
    </Array>
  </mxGeometry>
</mxCell>


<!-- ============================================
     CONNECTION WITH LABEL POSITION
     Offset label from center of edge
     ============================================ -->
<mxCell id="{ID}"
  value="{LABEL}"
  style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=1;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#333333;"
  edge="1"
  parent="{PARENT}"
  source="{SOURCE}"
  target="{TARGET}">
  <mxGeometry relative="1" as="geometry">
    <mxPoint as="offset" x="0" y="-10" />
  </mxGeometry>
</mxCell>


<!-- ============================================
     SELF-REFERENCING LOOP
     Process loops back to itself
     ============================================ -->
<mxCell id="{ID}"
  value="{LABEL}"
  style="edgeStyle=orthogonalEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=1;endArrow=classic;endFill=1;exitX=1;exitY=0.5;entryX=0.5;entryY=0;"
  edge="1"
  parent="{PARENT}"
  source="{SOURCE}"
  target="{SOURCE}">
  <mxGeometry relative="1" as="geometry">
    <Array as="points">
      <mxPoint x="200" y="100" />
      <mxPoint x="200" y="50" />
      <mxPoint x="125" y="50" />
    </Array>
  </mxGeometry>
</mxCell>


