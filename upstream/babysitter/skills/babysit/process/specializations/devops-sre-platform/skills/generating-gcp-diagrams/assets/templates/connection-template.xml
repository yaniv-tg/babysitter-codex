<!-- ============================================
     CONSOLIDATED CONNECTION (Target Container)
     Use when multiple connections cross the same
     corridor. Target the container group instead
     of individual nodes to reduce visual clutter.
     ============================================ -->
<mxCell id="{ID}"
  value="write / load"
  style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=2;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#333333;"
