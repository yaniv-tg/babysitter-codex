<!--
  Connection Template Reference

  This file contains template patterns for adding connections between shapes.
  Copy and customize these patterns, replacing placeholder values.

  Placeholders:
  - {ID}      : Unique identifier for the connection (e.g., "conn1", "edge1")
  - {LABEL}   : Optional label text on the connection
  - {SOURCE}  : ID of the source shape
  - {TARGET}  : ID of the target shape (can be a container ID for consolidated connections)
  - {PARENT}  : Parent cell ID (usually "1")

  Important:
  - source and target must reference existing mxCell IDs with vertex="1"
  - Connections are added AFTER all shapes in the XML
  - ALWAYS include labelBackgroundColor=#FFFFFF on labeled connections
  - When 3+ connections cross the same corridor, consolidate them into
    a single connection targeting the container group instead of individual nodes

  Best Practices:
  - Use labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#333333; on all labeled edges
  - Avoid 3+ parallel connectors between the same pair of groups
  - Consolidate parallel connections: e.g. "write / load" instead of separate "write" and "load"
  - Connections CAN target container cells directly to reduce clutter
-->

<!-- ============================================
     SOLID ARROW (Standard)
     Most common - data flow, API calls, requests
     ============================================ -->
<mxCell id="{ID}"
  value="{LABEL}"
  style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=1;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#333333;"
  edge="1"
  parent="{PARENT}"
  source="{SOURCE}"
  target="{TARGET}">
  <mxGeometry relative="1" as="geometry" />
</mxCell>


<!-- ============================================
     SOLID ARROW (No Label)
     ============================================ -->
<mxCell id="{ID}"
  style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=1;endArrow=classic;endFill=1;"
  edge="1"
  parent="{PARENT}"
  source="{SOURCE}"
  target="{TARGET}">
  <mxGeometry relative="1" as="geometry" />
</mxCell>


<!-- ============================================
     DASHED ARROW
     Optional flows, async operations, references
     ============================================ -->
<mxCell id="{ID}"
  value="{LABEL}"
  style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1;dashed=1;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#333333;"
  edge="1"
  parent="{PARENT}"
  source="{SOURCE}"
  target="{TARGET}">
  <mxGeometry relative="1" as="geometry" />
</mxCell>


<!-- ============================================
