<?xml version="1.0" encoding="UTF-8"?>
<!--
  DrawIO Base Template

  Usage:
  1. Copy this template as starting point
  2. Replace {TIMESTAMP} with current ISO timestamp
  3. Add shapes and connections inside <root> after the two base mxCells
  4. Adjust pageWidth/pageHeight as needed

  Standard page sizes:
  - GCP Standard (use this): 1200 x 780  ← REQUIRED for correct rendering in DrawIO Desktop
  - Letter: 850 x 1100
  - A4: 827 x 1169
  - Wide: 1600 x 900
-->
<mxfile host="app.diagrams.net" modified="{TIMESTAMP}" agent="DrawIO Architect Skill" version="22.0.0" type="device">
  <diagram name="Architecture" id="architecture-diagram">
    <mxGraphModel dx="1434" dy="844" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="780" math="0" shadow="0">
      <root>
        <!-- Required base cells - do not remove -->
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!--
          Add your diagram elements below this line.

          Order of elements:
          1. Containers (largest to smallest)
          2. Service icons (set parent to container ID)
          3. Connections (reference source/target IDs)

          Example container:
          <mxCell id="vpc1" value="VPC-SC" style="..." vertex="1" parent="1">
            <mxGeometry x="50" y="50" width="600" height="400" as="geometry" />
          </mxCell>

          Example service (inside container):
          <mxCell id="run1" value="Cloud Run" style="..." vertex="1" parent="vpc1">
            <mxGeometry x="100" y="100" width="50" height="50" as="geometry" />
          </mxCell>

          Example connection:
          <mxCell id="conn1" edge="1" parent="1" source="run1" target="bq1" style="...">
            <mxGeometry relative="1" as="geometry" />
          </mxCell>
        -->

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
