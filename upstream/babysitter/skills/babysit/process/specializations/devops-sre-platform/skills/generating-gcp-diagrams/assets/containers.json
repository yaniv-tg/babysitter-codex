  "connection_styles": [
    {
      "connection_id": "solid_arrow",
      "name": "Solid Arrow",
      "description": "Standard solid connection with arrow",
      "style": "edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=1;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#333333;",
      "use_cases": ["data flow", "api call", "request"]
    },
    {
      "connection_id": "dashed_arrow",
      "name": "Dashed Arrow",
      "description": "Dashed connection with arrow",
      "style": "edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#666666;strokeWidth=1;dashed=1;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#333333;",
      "use_cases": ["optional flow", "async", "reference"]
    },
    {
      "connection_id": "bidirectional",
      "name": "Bidirectional Arrow",
      "description": "Two-way connection with arrows on both ends",
      "style": "edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=1;startArrow=classic;startFill=1;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#333333;",
      "use_cases": ["two-way communication", "sync", "read/write"]
    },
    {
      "connection_id": "no_arrow",
      "name": "Line (No Arrow)",
      "description": "Simple line connection without arrows",
      "style": "edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=1;endArrow=none;endFill=0;",
      "use_cases": ["association", "relationship", "link"]
    },
    {
      "connection_id": "curved_arrow",
      "name": "Curved Arrow",
      "description": "Curved connection with arrow",
      "style": "edgeStyle=entityRelationEdgeStyle;rounded=1;orthogonalLoop=1;jettySize=auto;html=1;strokeColor=#333333;strokeWidth=1;endArrow=classic;endFill=1;labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#333333;",
      "use_cases": ["complex routing", "alternative path"]
    }
  ],
  "connection_best_practices": {
    "label_styling": "Always include labelBackgroundColor=#FFFFFF;fontSize=10;fontColor=#333333; on labeled connections to prevent text overlapping icons.",
    "consolidation": "When 3+ connections cross the same corridor between groups, consolidate them into a single connection targeting the container group instead of individual nodes. Use a combined label like 'write / load' or 'read / write'. This dramatically improves readability.",
    "max_parallel": "Avoid more than 2 parallel connectors between the same pair of groups. If you need more, consolidate or use waypoints to route them differently.",
    "target_containers": "Connections can target container cells directly (not just leaf nodes). Use this to reduce visual clutter when multiple services in one group connect to multiple services in another."
  }
}
