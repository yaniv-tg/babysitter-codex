{
  "metadata": {
    "version": "1.2.0",
    "description": "Container and grouping styles for GCP architecture diagrams in DrawIO. Includes two-cell GCP Zone pattern and connection best practices.",
    "last_updated": "2026-01-27"
  },
  "containers": [
    {
      "container_id": "gcp_project",
      "name": "GCP Project Zone",
      "description": "Main GCP project boundary using the native DrawIO GCP/Zones shape. IMPORTANT: This is a TWO-CELL pattern — a plain rectangle container plus a small child cell with the GCP logo icon.",
      "two_cell_pattern": true,
      "container_cell": {
        "style": "fillColor=#F6F6F6;strokeColor=none;shadow=0;gradientColor=none;fontSize=14;align=left;spacing=10;fontColor=#717171;verticalAlign=top;spacingTop=-4;fontStyle=0;spacingLeft=40;html=1;whiteSpace=wrap;container=1;collapsible=0;recursiveResize=0;",
        "value_template": "<b>Google </b>Cloud Platform<br>{project_name}",
        "notes": "Do NOT add shape= to this cell. It must be a plain rectangle. The value uses HTML: <b>Google </b>Cloud Platform"
      },
      "logo_child_cell": {
        "style": "shape=mxgraph.gcp2.google_cloud_platform;fillColor=#F6F6F6;strokeColor=none;shadow=0;gradientColor=none;",
        "size": { "width": 23, "height": 20 },
        "geometry": "relative=1 with <mxPoint x=\"20\" y=\"10\" as=\"offset\" />",
        "notes": "Small GCP logo icon positioned at top-left of the container via relative geometry"
      },
      "colors": {
        "background": "#F6F6F6",
        "border": "none",
        "text": "#717171"
      },
      "default_size": { "width": 800, "height": 600 },
      "padding": { "top": 40, "right": 20, "bottom": 20, "left": 20 }
    },
    {
      "container_id": "gcp_vpc_sc",
      "name": "VPC Service Controls",
      "description": "VPC Service Controls perimeter container (light green)",
      "style": "rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F5E9;strokeColor=#4CAF50;strokeWidth=2;dashed=0;verticalAlign=top;fontSize=13;fontStyle=1;fontColor=#2E7D32;align=center;arcSize=5;container=1;collapsible=0;recursiveResize=0;",
      "label_template": "VPC Service Controls",
      "colors": {
        "background": "#E8F5E9",
        "border": "#4CAF50",
        "text": "#2E7D32"
      },
      "default_size": { "width": 700, "height": 500 },
      "padding": { "top": 50, "right": 20, "bottom": 20, "left": 20 }
    },
    {
      "container_id": "gcp_region",
      "name": "GCP Region",
      "description": "Regional boundary container",
      "style": "rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;strokeWidth=2;dashed=1;verticalAlign=top;fontSize=12;fontStyle=1;align=left;spacingLeft=10;container=1;collapsible=0;recursiveResize=0;",
      "label_template": "{region_name}",
      "colors": {
        "background": "#E3F2FD",
        "border": "#1976D2",
        "text": "#0D47A1"
