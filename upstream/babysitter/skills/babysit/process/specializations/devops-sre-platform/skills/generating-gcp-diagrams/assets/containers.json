      "style": "rounded=1;whiteSpace=wrap;html=1;fillColor=#E1F5FE;strokeColor=#03A9F4;strokeWidth=1;dashed=0;verticalAlign=top;fontSize=10;fontStyle=0;align=center;container=1;collapsible=0;recursiveResize=0;",
      "label_template": "{group_name}",
