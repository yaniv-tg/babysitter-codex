      "style": "rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#FF9800;strokeWidth=1;dashed=1;verticalAlign=top;fontSize=11;fontStyle=0;align=left;spacingLeft=8;container=1;collapsible=0;recursiveResize=0;",
      "label_template": "{zone_name}",
