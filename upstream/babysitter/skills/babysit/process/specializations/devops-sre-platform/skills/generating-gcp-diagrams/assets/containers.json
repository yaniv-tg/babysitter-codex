      "style": "rounded=1;whiteSpace=wrap;html=1;fillColor=#F3E5F5;strokeColor=#9C27B0;strokeWidth=2;dashed=0;verticalAlign=top;fontSize=12;fontStyle=1;align=center;container=1;collapsible=0;recursiveResize=0;",
      "label_template": "{system_name}",
