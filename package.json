{
  "name": "babysitter-codex",
  "version": "2.0.0",
  "description": "Babysitter SDK plugin for OpenAI Codex CLI — slash commands, orchestration, quality convergence, and lifecycle hooks",
  "main": "index.js",
  "scripts": {
    "test": "node test/integration.test.js && node test/harness.test.js",
    "test:unit": "node test/harness.test.js",
    "test:integration": "node test/integration.test.js",
    "lint": "find .codex -name '*.js' | xargs -I{} node --check {}",
    "orchestrate": "node .codex/orchestrate.js",
    "loop-control": ".codex/hooks/loop-control.sh",
    "health": "babysitter health --verbose",
    "discover": "babysitter skill:discover --json",
    "profile:user": "babysitter profile:render --user",
    "profile:project": "babysitter profile:render --project",
    "observe": "npx -y @yoavmayer/babysitter-observer-dashboard@latest --watch-dir ."
  },
  "keywords": ["babysitter", "codex", "orchestration", "ai-agent", "sdk-integration"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@a5c-ai/babysitter": "^0.0.175",
    "@a5c-ai/babysitter-sdk": "^0.0.173"
  }
}
