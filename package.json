{
  "name": "@yaniv-tg/babysitter-codex",
  "version": "0.1.5",
  "description": "Babysitter orchestration plugin for OpenAI Codex CLI - multi-step AI workflows with full upstream process library, 15 orchestration modes, and BOM-safe SKILL installation",
  "scripts": {
    "test": "node test/integration.test.js && node test/harness.test.js && node test/plugin.test.js && node test/features-1-10.test.js && node test/process-mining.test.js",
    "test:unit": "node test/harness.test.js",
    "test:integration": "node test/integration.test.js",
    "test:plugin": "node test/plugin.test.js",
    "test:features": "node test/features-1-10.test.js",
    "test:scenario": "node test/full-session-scenario.js",
    "test:long-scenario": "node test/full-session-long-run.js",
    "check:mapping": "node scripts/check-mapping-contract.js",
    "manifest:generate": "node scripts/generate-content-manifest.js",
    "manifest:verify": "node scripts/verify-content-manifest.js",
    "team:install": "node scripts/team-install.js",
    "check:compat": "node scripts/check-compat.js",
    "mine:process": "node scripts/mine-process.js",
    "sync:upstream": "node scripts/sync-from-upstream.js",
    "check:upstream": "node scripts/check-upstream-parity.js",
    "lint": "find .codex -name '*.js' | xargs -I{} node --check {}",
    "postinstall": "node bin/postinstall.js",
    "preuninstall": "node bin/uninstall.js"
  },
  "files": [
    "SKILL.md",
    "CHANGELOG.md",
    "agents/",
    "commands/",
    ".codex/",
    "bin/",
    "config/",
    "docs/",
    "packages/",
    "scripts/",
    "test/",
    "upstream/",
    "babysitter.lock.json",
    "README.md"
  ],
  "keywords": [
    "babysitter",
    "codex",
    "orchestration",
    "ai-agent",
    "sdk-integration",
    "codex-skill"
  ],
  "author": "a5c.ai",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yaniv-tg/babysitter-codex"
  },
  "homepage": "https://github.com/yaniv-tg/babysitter-codex#readme",
  "dependencies": {
    "@a5c-ai/babysitter-sdk": "^0.0.173"
  }
}
