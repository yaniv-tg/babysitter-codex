{
  "name": "babysitter",
  "version": "4.0.143",
  "description": "Babysitter orchestration plugin for Codex CLI — structured multi-step AI workflows with quality convergence, lifecycle hooks, and slash commands",
  "author": "a5c.ai",
  "license": "MIT",
  "hooks": {
    "SessionStart": "hooks/babysitter-session-start.sh",
    "Stop": "hooks/babysitter-stop-hook.sh"
  },
  "commands": [
    { "name": "babysitter:call", "file": "skills/babysitter/call/SKILL.md", "aliases": ["babysitter:babysit", "babysitter"], "description": "Start a babysitter orchestration run", "argumentHint": "Specific instructions for the run" },
    { "name": "babysitter:yolo", "file": "skills/babysitter/yolo/SKILL.md", "description": "Non-interactive autonomous orchestration (no breakpoints)", "argumentHint": "Specific instructions for the run" },
    { "name": "babysitter:resume", "file": "skills/babysitter/resume/SKILL.md", "description": "Resume an existing orchestration run", "argumentHint": "[run-id] Optional run ID to resume" },
    { "name": "babysitter:plan", "file": "skills/babysitter/plan/SKILL.md", "description": "Plan a workflow without executing it", "argumentHint": "Specific instructions for the plan" },
    { "name": "babysitter:forever", "file": "skills/babysitter/forever/SKILL.md", "description": "Start a never-ending periodic orchestration run", "argumentHint": "Specific instructions for the run" },
    { "name": "babysitter:doctor", "file": "skills/babysitter/doctor/SKILL.md", "description": "Diagnose babysitter run health", "argumentHint": "[run-id] Optional run ID to diagnose" },
    { "name": "babysitter:observe", "file": "skills/babysitter/observe/SKILL.md", "description": "Launch the observer dashboard", "argumentHint": "[--watch-dir <dir>] or 'stop'" },
    { "name": "babysitter:help", "file": "skills/babysitter/help/SKILL.md", "description": "Help and documentation", "argumentHint": "[command|process|skill|agent] topic to get help on" },
    { "name": "babysitter:project-install", "file": "skills/babysitter/project-install/SKILL.md", "description": "Set up a project for babysitting", "argumentHint": "Specific instructions" },
    { "name": "babysitter:user-install", "file": "skills/babysitter/user-install/SKILL.md", "description": "Set up babysitter for a user", "argumentHint": "Specific instructions" },
    { "name": "babysitter:assimilate", "file": "skills/babysitter/assimilate/SKILL.md", "description": "Assimilate external methodology into babysitter processes", "argumentHint": "Target (repo URL, harness name, or spec path)" }
  ],
  "skills": [],
  "repository": {
    "type": "git",
    "url": "https://github.com/yaniv-tg/babysitter-codex"
  },
  "keywords": ["orchestration", "workflow", "codex", "babysitter", "slash-commands", "plugin"]
}
